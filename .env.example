# Helius WebSocket URL (get from helius.dev)
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Solana RPC for outsmart (can use Helius HTTP endpoint)
MAINNET_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Your wallet private key (base58 encoded)
PRIVATE_KEY=your_base58_private_key_here

# Your wallet public address
WALLET_ADDRESS=your_wallet_address_here

# Optional: Priority fee for sells (in microLamports)
PRIORITY_FEE=80000

# Optional: Default slippage for sells (in bps)
DEFAULT_SLIPPAGE_BPS=10000
